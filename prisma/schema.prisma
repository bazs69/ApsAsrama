generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String          @id @default(uuid())
  name          String
  photo         String?
  username      String?         @unique
  email         String          @unique
  password      String
  roleId        String?
  isActive      Boolean         @default(true)
  satkerId      String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  exportHistory ExportHistory[]
  role          Role?           @relation(fields: [roleId], references: [id])
  satker        Satker?         @relation(fields: [satkerId], references: [id])
}

model Room {
  id        String     @id @default(uuid())
  number    String
  capacity  Int
  floor     Int
  status    RoomStatus @default(AVAILABLE)
  daerahId  String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  residents Resident[]
  daerah    Daerah?    @relation(fields: [daerahId], references: [id])

  @@unique([daerahId, number])
  @@index([status])
  @@index([floor])
}

model Resident {
  id              String                @id @default(uuid())
  name            String
  photo           String?
  nim             String?               @unique
  niup            String?               @unique
  angkatan        String?
  prodi           String?
  wilayah         String?
  daerah          String?
  kotaAsal        String?
  fakultas        String?
  phone           String?
  tempatLahir     String?
  tanggalLahir    DateTime?
  gender          String?
  nik             String?
  alamatLengkap   String?
  kodePos         String?
  fakultasId      String?
  prodiId         String?
  angkatanId      String?
  roomId          String?
  asalCountryId   String?
  asalProvinceId  String?
  asalRegencyId   String?
  asalDistrictId  String?
  asalVillageId   String?
  status          ResidentStatus        @default(ACTIVE)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  absensiApel     AbsensiApel[]
  absensiKegiatan AbsensiKegiatan[]
  assignments     Assignment[]
  angkatanRef     Angkatan?             @relation(fields: [angkatanId], references: [id])
  asalCountry     Country?              @relation(fields: [asalCountryId], references: [id])
  asalDistrict    District?             @relation(fields: [asalDistrictId], references: [id])
  asalProvince    Province?             @relation(fields: [asalProvinceId], references: [id])
  asalRegency     Regency?              @relation(fields: [asalRegencyId], references: [id])
  asalVillage     Village?              @relation(fields: [asalVillageId], references: [id])
  fakultasRef     Fakultas?             @relation(fields: [fakultasId], references: [id])
  prodiRef        Prodi?                @relation(fields: [prodiId], references: [id])
  room            Room?                 @relation(fields: [roomId], references: [id])
  roomHistory     ResidentRoomHistory[]

  @@index([roomId])
  @@index([status])
  @@index([angkatan])
}

model Satker {
  id             String                 @id @default(uuid())
  name           String                 @unique
  picName        String
  picPhone       String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  assignments    Assignment[]
  laporanBulanan LaporanBulananSatker[]
  users          User[]
}

model Assignment {
  id          String                @id @default(uuid())
  residentId  String
  satkerId    String
  position    String                @default("Anggota")
  status      String                @default("ACTIVE")
  startDate   DateTime              @default(now())
  endDate     DateTime?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  resident    Resident              @relation(fields: [residentId], references: [id], onDelete: Cascade)
  satker      Satker                @relation(fields: [satkerId], references: [id], onDelete: Cascade)
  monitorings MonitoringPenugasan[]

  @@unique([residentId, satkerId])
  @@index([satkerId])
}

model MonitoringPenugasan {
  id                String     @id @default(uuid())
  assignmentId      String     @map("penugasan_id")
  tanggalMonitoring DateTime   @map("tanggal_monitoring")
  statusMonitoring  String     @map("status_monitoring")
  catatanMonitoring String?    @map("catatan_monitoring")
  catatanPembimbing String?    @map("catatan_pembimbing")
  dokumentasi       String?
  createdBy         String?    @map("created_by")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")
  assignment        Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@index([assignmentId])
  @@index([tanggalMonitoring])
  @@map("monitoring_penugasan")
}

model LaporanBulananSatker {
  id         String   @id @default(cuid())
  satkerId   String
  bulan      Int
  tahun      Int
  kesimpulan String?
  status     String   @default("DRAFT")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  satker     Satker   @relation(fields: [satkerId], references: [id])

  @@unique([satkerId, bulan, tahun])
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  isSystem    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  permissions RolePermission[]
  users       User[]
}

model Permission {
  id          String           @id @default(uuid())
  module      String
  action      String
  code        String           @unique
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  roles       RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Muallim {
  id        String           @id @default(uuid())
  name      String
  kbm       String
  status    MuallimStatus    @default(ACTIVE)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  absensi   AbsensiMuallim[]
}

model AbsensiMuallim {
  id         String        @id @default(uuid())
  hari       String
  tanggal    DateTime
  muallimId  String
  status     AbsensiStatus @default(HADIR)
  keterangan String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  muallim    Muallim       @relation(fields: [muallimId], references: [id])

  @@index([muallimId])
  @@index([tanggal])
}

model Kegiatan {
  id         String            @id @default(uuid())
  nama       String
  tanggal    DateTime
  keterangan String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  absensi    AbsensiKegiatan[]

  @@index([tanggal])
}

model AbsensiKegiatan {
  id         String          @id @default(uuid())
  kegiatanId String
  residentId String
  status     KehadiranStatus @default(HADIR)
  keterangan String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  kegiatan   Kegiatan        @relation(fields: [kegiatanId], references: [id], onDelete: Cascade)
  resident   Resident        @relation(fields: [residentId], references: [id], onDelete: Cascade)

  @@unique([kegiatanId, residentId])
  @@index([residentId])
}

model Apel {
  id         String        @id @default(uuid())
  tanggal    DateTime
  keterangan String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  absensi    AbsensiApel[]

  @@index([tanggal])
}

model AbsensiApel {
  id         String        @id @default(uuid())
  apelId     String
  residentId String
  status     KehadiranApel @default(HADIR)
  keterangan String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  apel       Apel          @relation(fields: [apelId], references: [id], onDelete: Cascade)
  resident   Resident      @relation(fields: [residentId], references: [id], onDelete: Cascade)

  @@unique([apelId, residentId])
  @@index([residentId])
}

model Wilayah {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  daerahs   Daerah[]
}

model Daerah {
  id        String   @id @default(uuid())
  name      String   @unique
  wilayahId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  wilayah   Wilayah? @relation(fields: [wilayahId], references: [id])
  rooms     Room[]
}

model Fakultas {
  id        String     @id @default(uuid())
  name      String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  prodis    Prodi[]
  residents Resident[]
}

model Prodi {
  id         String     @id @default(uuid())
  name       String
  fakultasId String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  angkatans  Angkatan[]
  fakultas   Fakultas   @relation(fields: [fakultasId], references: [id], onDelete: Cascade)
  residents  Resident[]

  @@unique([name, fakultasId])
}

model Angkatan {
  id        String     @id @default(uuid())
  name      String
  prodiId   String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  prodi     Prodi      @relation(fields: [prodiId], references: [id], onDelete: Cascade)
  residents Resident[]

  @@unique([name, prodiId])
}

model Kbm {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExportHistory {
  id         String   @id @default(uuid())
  fileName   String
  reportType String
  userId     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Country {
  id        String     @id @default(uuid())
  code      String     @unique
  name      String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  provinces Province[]
  residents Resident[]

  @@index([name])
}

model Province {
  id        String     @id @default(uuid())
  code      String     @unique
  name      String
  countryId String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  country   Country    @relation(fields: [countryId], references: [id], onDelete: Cascade)
  regencies Regency[]
  residents Resident[]

  @@unique([name, countryId])
  @@index([name])
  @@index([countryId])
}

model Regency {
  id         String     @id @default(uuid())
  code       String     @unique
  name       String
  provinceId String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  districts  District[]
  province   Province   @relation(fields: [provinceId], references: [id], onDelete: Cascade)
  residents  Resident[]

  @@unique([name, provinceId])
  @@index([name])
  @@index([provinceId])
}

model District {
  id        String     @id @default(uuid())
  code      String     @unique
  name      String
  regencyId String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  regency   Regency    @relation(fields: [regencyId], references: [id], onDelete: Cascade)
  residents Resident[]
  villages  Village[]

  @@unique([name, regencyId])
  @@index([name])
  @@index([regencyId])
}

model Village {
  id         String     @id @default(uuid())
  code       String     @unique
  name       String
  districtId String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  residents  Resident[]
  district   District   @relation(fields: [districtId], references: [id], onDelete: Cascade)

  @@unique([name, districtId])
  @@index([name])
  @@index([districtId])
}

model AuditLog {
  id          String   @id @default(uuid())
  action      String
  entityType  String
  entityId    String?
  oldValue    Json?
  newValue    Json?
  performedBy String?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
}

model ResidentRoomHistory {
  id           String   @id @default(uuid())
  residentId   String
  fromRoomId   String?
  fromRoom     String?
  toRoomId     String?
  toRoom       String?
  fromWilayah  String?
  fromDaerah   String?
  toWilayah    String?
  toDaerah     String?
  alasan       String?
  transferedBy String?
  createdAt    DateTime @default(now())
  resident     Resident @relation(fields: [residentId], references: [id], onDelete: Cascade)

  @@index([residentId])
  @@index([createdAt])
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
}

enum ResidentStatus {
  ACTIVE
  INACTIVE
}

enum MuallimStatus {
  ACTIVE
  INACTIVE
}

enum AbsensiStatus {
  HADIR
  IZIN
  DIWAKILKAN
}

enum KehadiranStatus {
  HADIR
  IZIN
  SAKIT
  ALPA
}

enum KehadiranApel {
  HADIR
  ALPA
  IZIN
}
