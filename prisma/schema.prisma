generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  photo     String?  // Foto profil
  username  String?  @unique
  email     String   @unique
  password  String
  roleId    String?
  role      Role?    @relation(fields: [roleId], references: [id])
  isActive  Boolean  @default(true)
  satkerId  String?
  satker    Satker?  @relation(fields: [satkerId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  exportHistory ExportHistory[]
}

model Room {
  id        String     @id @default(uuid())
  number    String
  capacity  Int
  floor     Int
  status    RoomStatus @default(AVAILABLE)
  residents Resident[]
  daerahId  String?
  daerah    Daerah?    @relation(fields: [daerahId], references: [id])
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([daerahId, number])
  @@index([status])
  @@index([floor])
}

model Resident {
  id        String   @id @default(uuid())
  name      String
  photo     String?  // Foto santri
  nim       String?  @unique // Nomor Induk Mahasiswa (opsional)
  niup      String?  @unique // Nomor Induk Unik Pesantren (opsional)
  angkatan  String?  // Tahun angkatan, misal: "2021"
  prodi     String?  // Program studi, misal: "Teknik Informatika"
  wilayah   String?  // Wilayah asal
  daerah    String?  // Daerah asal
  kotaAsal  String?  // Kota Asal
  fakultas  String?  // Fakultas
  phone     String?
  
  // New Biodata fields
  tempatLahir   String?
  tanggalLahir  DateTime?
  gender        String?
  nik           String?

  // New Domisili fields
  alamatLengkap String?
  kodePos       String?

  // New Pendidikan relations
  fakultasId    String?
  fakultasRef   Fakultas? @relation(fields: [fakultasId], references: [id])
  prodiId       String?
  prodiRef      Prodi?    @relation(fields: [prodiId], references: [id])
  angkatanId    String?
  angkatanRef   Angkatan? @relation(fields: [angkatanId], references: [id])

  roomId    String?
  room      Room?    @relation(fields: [roomId], references: [id])
  
  asalCountryId  String?
  asalCountry    Country? @relation(fields: [asalCountryId], references: [id])
  asalProvinceId String?
  asalProvince   Province? @relation(fields: [asalProvinceId], references: [id])
  asalRegencyId  String?
  asalRegency    Regency? @relation(fields: [asalRegencyId], references: [id])
  asalDistrictId String?
  asalDistrict   District? @relation(fields: [asalDistrictId], references: [id])
  asalVillageId  String?
  asalVillage    Village? @relation(fields: [asalVillageId], references: [id])
  
  status    ResidentStatus @default(ACTIVE)
  assignments Assignment[]
  absensiKegiatan AbsensiKegiatan[]
  absensiApel     AbsensiApel[]
  roomHistory     ResidentRoomHistory[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roomId])
  @@index([status])
  @@index([angkatan])
}

model Satker {
  id          String       @id @default(uuid())
  name        String       @unique
  picName     String       // Penanggung jawab satker
  picPhone    String?      // Kontak PJ satker
  users       User[]
  assignments Assignment[]
  laporanBulanan LaporanBulananSatker[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Assignment {
  id          String     @id @default(uuid())
  residentId  String
  resident    Resident   @relation(fields: [residentId], references: [id], onDelete: Cascade)
  satkerId    String
  satker      Satker     @relation(fields: [satkerId], references: [id], onDelete: Cascade)
  position    String     @default("Anggota") // Ketua, Sekretaris, Anggota, dll.
  status      String     @default("ACTIVE")  // ACTIVE, COMPLETED
  startDate   DateTime   @default(now())
  endDate     DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  monitorings MonitoringPenugasan[]

  @@unique([residentId, satkerId])
  @@index([satkerId])
}

model MonitoringPenugasan {
  id                String     @id @default(uuid())
  assignmentId      String     @map("penugasan_id")
  assignment        Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  tanggalMonitoring DateTime   @map("tanggal_monitoring")
  statusMonitoring  String     @map("status_monitoring")
  catatanMonitoring String?    @map("catatan_monitoring") @db.Text
  catatanPembimbing String?    @map("catatan_pembimbing") @db.Text
  dokumentasi       String?    @db.Text
  createdBy         String?    @map("created_by")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  @@index([assignmentId])
  @@index([tanggalMonitoring])
  @@map("monitoring_penugasan")
}

model LaporanBulananSatker {
  id             String   @id @default(cuid())
  satkerId       String
  bulan          Int
  tahun          Int
  kesimpulan     String?  @db.Text
  status         String   @default("DRAFT") // DRAFT, SUBMITTED
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  satker         Satker   @relation(fields: [satkerId], references: [id])

  @@unique([satkerId, bulan, tahun])
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  isSystem    Boolean          @default(false)
  permissions RolePermission[]
  users       User[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Permission {
  id          String           @id @default(uuid())
  module      String           // e.g. "Data Santri", "Dashboard"
  action      String           // e.g. "View", "Create", "Update", "Delete"
  code        String           @unique // e.g. "santri.view"
  description String?
  roles       RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
}

enum ResidentStatus {
  ACTIVE
  INACTIVE
}

model Muallim {
  id        String        @id @default(uuid())
  name      String
  kbm       String        // Kegiatan Belajar Mengajar
  status    MuallimStatus @default(ACTIVE)
  absensi   AbsensiMuallim[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

enum MuallimStatus {
  ACTIVE
  INACTIVE
}

model AbsensiMuallim {
  id          String        @id @default(uuid())
  hari        String
  tanggal     DateTime
  muallimId   String
  muallim     Muallim       @relation(fields: [muallimId], references: [id])
  status      AbsensiStatus @default(HADIR)
  keterangan  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([muallimId])
  @@index([tanggal])
}

enum AbsensiStatus {
  HADIR
  IZIN
  DIWAKILKAN
}

model Kegiatan {
  id          String   @id @default(uuid())
  nama        String   // Misal: "Kajian Subuh", "Kerja Bakti"
  tanggal     DateTime
  keterangan  String?
  absensi     AbsensiKegiatan[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tanggal])
}

model AbsensiKegiatan {
  id          String   @id @default(uuid())
  kegiatanId  String
  kegiatan    Kegiatan @relation(fields: [kegiatanId], references: [id], onDelete: Cascade)
  residentId  String
  resident    Resident @relation(fields: [residentId], references: [id], onDelete: Cascade)
  status      KehadiranStatus @default(HADIR)
  keterangan  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([kegiatanId, residentId])
  @@index([residentId])
}

enum KehadiranStatus {
  HADIR
  IZIN
  SAKIT
  ALPA
}

model Apel {
  id          String   @id @default(uuid())
  tanggal     DateTime
  keterangan  String?
  absensi     AbsensiApel[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tanggal])
}

model AbsensiApel {
  id          String   @id @default(uuid())
  apelId      String
  apel        Apel     @relation(fields: [apelId], references: [id], onDelete: Cascade)
  residentId  String
  resident    Resident @relation(fields: [residentId], references: [id], onDelete: Cascade)
  status      KehadiranApel @default(HADIR)
  keterangan  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([apelId, residentId])
  @@index([residentId])
}

enum KehadiranApel {
  HADIR
  ALPA
  IZIN
}

model Wilayah {
  id        String   @id @default(uuid())
  name      String   @unique
  daerahs   Daerah[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Daerah {
  id        String   @id @default(uuid())
  name      String   @unique
  wilayahId String?
  wilayah   Wilayah? @relation(fields: [wilayahId], references: [id])
  rooms     Room[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Fakultas {
  id        String     @id @default(uuid())
  name      String     @unique
  prodis    Prodi[]
  residents Resident[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Prodi {
  id          String     @id @default(uuid())
  name        String
  fakultasId  String
  fakultas    Fakultas   @relation(fields: [fakultasId], references: [id], onDelete: Cascade)
  angkatans   Angkatan[]
  residents   Resident[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([name, fakultasId])
}

model Angkatan {
  id        String     @id @default(uuid())
  name      String
  prodiId   String
  prodi     Prodi      @relation(fields: [prodiId], references: [id], onDelete: Cascade)
  residents Resident[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([name, prodiId])
}

model Kbm {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExportHistory {
  id          String   @id @default(uuid())
  fileName    String
  reportType  String
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([createdAt])
}

model Country {
  id        String     @id @default(uuid())
  code      String     @unique
  name      String     @unique
  provinces Province[]
  residents Resident[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([name])
}

model Province {
  id        String     @id @default(uuid())
  code      String     @unique
  name      String
  countryId String
  country   Country    @relation(fields: [countryId], references: [id], onDelete: Cascade)
  regencies Regency[]
  residents Resident[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([name, countryId])
  @@index([name])
  @@index([countryId])
}

model Regency {
  id         String     @id @default(uuid())
  code       String     @unique
  name       String
  provinceId String
  province   Province   @relation(fields: [provinceId], references: [id], onDelete: Cascade)
  districts  District[]
  residents  Resident[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@unique([name, provinceId])
  @@index([name])
  @@index([provinceId])
}

model District {
  id         String     @id @default(uuid())
  code       String     @unique
  name       String
  regencyId  String
  regency    Regency    @relation(fields: [regencyId], references: [id], onDelete: Cascade)
  villages   Village[]
  residents  Resident[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@unique([name, regencyId])
  @@index([name])
  @@index([regencyId])
}

model Village {
  id         String     @id @default(uuid())
  code       String     @unique
  name       String
  districtId String
  district   District   @relation(fields: [districtId], references: [id], onDelete: Cascade)
  residents  Resident[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@unique([name, districtId])
  @@index([name])
  @@index([districtId])
}

model AuditLog {
  id          String   @id @default(uuid())
  action      String   // CREATE, UPDATE, DELETE, IMPORT
  entityType  String   // COUNTRY, PROVINCE, REGENCY, DISTRICT, VILLAGE, RESIDENT
  entityId    String?
  oldValue    Json?
  newValue    Json?
  performedBy String?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
}

model ResidentRoomHistory {
  id           String   @id @default(uuid())
  residentId   String
  resident     Resident @relation(fields: [residentId], references: [id], onDelete: Cascade)
  fromRoomId   String?  // null = masuk pertama kali
  fromRoom     String?  // nomor kamar asal (string copy)
  toRoomId     String?
  toRoom       String?  // nomor kamar tujuan (string copy)
  fromWilayah  String?
  fromDaerah   String?
  toWilayah    String?
  toDaerah     String?
  alasan       String?  @db.Text
  transferedBy String?  // email / nama operator
  createdAt    DateTime @default(now())

  @@index([residentId])
  @@index([createdAt])
}
